# Copy this file to one of the following locations and fill in your TuShare token:
# - ~/.openclaw/stock-tools.env
# - <workspace>/.stock-tools.env
#
# OpenClaw's stock-tools plugin reads these values directly, so the gateway
# service does not need a shell-exported environment variable.

TUSHARE_TOKEN=
# Optional:
# TUSHARE_BASE_URL=http://api.tushare.pro
